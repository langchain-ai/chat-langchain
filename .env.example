# LangChain Docs Agent Environment Variables

# =============================================================================
# LLM Provider API Keys (at least one required)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
BASETEN_API_KEY=your_baseten_api_key_here

# =============================================================================
# Documentation Search (Mintlify)
# =============================================================================
MINTLIFY_API_URL=https://api-dsc.mintlify.com/v1/search/docs.langchain.com
MINTLIFY_API_KEY=mint_dsc_your_mintlify_api_key_here

# =============================================================================
# Pylon Knowledge Base
# =============================================================================
PYLON_API_KEY=pylon_api_key_here
PYLON_KB_ID=your_pylon_kb_id_here

# =============================================================================
# LangSmith - for tracing and monitoring
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key_here
LANGSMITH_PROJECT=docs-agent

# Workspace that owns Hub prompts used for root-trace prompt_source / prompt_commit
# provenance. On MDA deploys this is often the legacy Chat LangChain org, not the
# deployment workspace (LANGSMITH_WORKSPACE_ID). Required for prompt_commit to
# resolve when prompts live in another workspace.
# LANGSMITH_PROMPT_WORKSPACE_ID=ebbaf2eb-769b-4505-aca2-d11de10372a4

# Optional. MDA deploy does not forward LANGSMITH_API_KEY (host-reserved); the
# injected host key may not be able to read the prompt workspace above. Set a
# key that can, used only for Hub provenance pulls.
# LANGSMITH_PROMPT_API_KEY=lsv2_your_key_with_prompt_workspace_access

# =============================================================================
# Frontend Optional Login (Supabase Auth)
# =============================================================================
# Used by frontend/ to mimic support portal LangSmith account login.
# The app still works without these values by allowing users to continue as guests.
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_EU_URL=https://your-eu-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_EU_ANON_KEY=your_eu_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_APAC_URL=https://your-apac-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_APAC_ANON_KEY=your_apac_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_AWS_URL=https://your-aws-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_AWS_ANON_KEY=your_aws_supabase_anon_key_here

# Used by LangGraph auth.py to validate Supabase access tokens.
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_EU_URL=https://your-eu-supabase-project.supabase.co
SUPABASE_EU_ANON_KEY=your_eu_supabase_anon_key_here
SUPABASE_APAC_URL=https://your-apac-supabase-project.supabase.co
SUPABASE_APAC_ANON_KEY=your_apac_supabase_anon_key_here
SUPABASE_AWS_URL=https://your-aws-supabase-project.supabase.co
SUPABASE_AWS_ANON_KEY=your_aws_supabase_anon_key_here

# Used only by the MDA deployment: the managed `guest` provider signs and verifies
# guest tokens with this HS256 key. The frontend no longer signs guest tokens; it
# calls the deployment's managed `POST /identity/guest` endpoint instead.
MDA_GUEST_SIGNING_KEY=guest_signing_key

# Optional shared LangGraph gate. Must match backend LANGGRAPH_AUTH_SECRET.
LANGGRAPH_AUTH_SECRET=your_langgraph_auth_secret_here
NEXT_PUBLIC_LANGGRAPH_AUTH_KEY=your_langgraph_auth_secret_here
